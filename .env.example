# ==========================================
# LoopedWithLove — Environment Variables
# Copy this file to .env.local and fill in your values
# ==========================================

# Google Apps Script Web App URL (deploy your Code.gs as a Web App and paste the URL here)
NEXT_PUBLIC_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Secret API key for admin write operations (must match value set in Apps Script Properties)
APPS_SCRIPT_API_KEY=your-secret-api-key-here

# Admin Panel Password
ADMIN_PASSWORD=your-admin-password-here

# Your site's public URL
NEXT_PUBLIC_SITE_URL=https://loopedwithlove.vercel.app

# WhatsApp number (country code + number, no spaces or +)
NEXT_PUBLIC_WHATSAPP_NUMBER=919999999999

# Google Form URL for adding products (used in Admin Panel "Add Product" button)
NEXT_PUBLIC_GOOGLE_FORM_URL=https://forms.google.com/your-form-url

# Secret for on-demand revalidation (any random string)
REVALIDATION_SECRET=my-revalidation-secret

# Google Analytics 4 (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
